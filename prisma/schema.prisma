generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum SubscriptionTier {
  FREE
  PLUS
  PRO
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}


enum NotificationType {
  SYSTEM
  TRAVEL
  WEATHER
  RIDE_STATUS
  PLANNER
  COLLABORATION
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}
enum FeedbackStatus {
  NEW
  REVIEWED
}

enum AttractionCategory {
  RIDE
  SHOW
  DINING
  PLAY
}

enum AttractionOperationalStatus {
  OPEN
  TEMPORARILY_CLOSED
  WEATHER_DELAY
}

enum TripStatus {
  DRAFT
  PLANNED
  LIVE
  COMPLETED
}

enum PlannerStatus {
  ACTIVE
  ARCHIVED
}

enum TripAccessRole {
  NONE
  VIEW
  EDIT
}

enum TripAttendanceStatus {
  INVITED
  ATTENDING
  MAYBE
  NOT_ATTENDING
}

enum TripLogisticsCategory {
  DOCS
  TRANSPORT
  GEAR
  TIME_OFF
  LODGING
  OTHER
}

enum TripLogisticsTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TripLogisticsTaskSource {
  MARA
  MANUAL
}

enum ThrillTolerance {
  LOW
  MEDIUM
  HIGH
}

enum WalkingTolerance {
  LOW
  MEDIUM
  HIGH
}

enum ItineraryItemType {
  RIDE
  SHOW
  DINING
  BREAK
}

enum ItineraryItemStatus {
  PLANNED
  COMPLETED
  SKIPPED
  CANCELLED
}

model User {
  id                            String                   @id @default(cuid())
  email                         String                   @unique
  googleId                      String?                  @unique
  emailVerifiedAt               DateTime?
  firstName                     String?
  lastName                      String?
  name                          String?
  profileImageDataUrl           String?
  authProvider                  AuthProvider             @default(LOCAL)
  onboardingStatus              OnboardingStatus         @default(NOT_STARTED)
  onboardingCurrentStep         Int                      @default(0)
  onboardingStartedAt           DateTime?
  onboardingCompletedAt         DateTime?
  subscriptionTier              SubscriptionTier         @default(FREE)
  subscriptionStatus            SubscriptionStatus       @default(INACTIVE)
  stripeCustomerId              String?                  @unique
  stripeSubscriptionId          String?                  @unique
  stripePriceId                 String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean                  @default(false)
  passwordHash                  String
  maraPreviewRepliesUsed        Int                      @default(0)
  isFirstTime                   Boolean                  @default(true)
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt
  preference                    UserPreference?
  sessions                      Session[]
  trips                         Trip[]
  tripCollaborations            TripCollaborator[]
  notifications                 Notification[]
  triggeredNotifications        Notification[]           @relation("NotificationActor")
  maraRequestLogs               MaraRequestLog[]
  people                        UserContact[]            @relation("UserContactOwner")
  listedInPeople                UserContact[]            @relation("UserContactMember")
  sentUserContactInvites        UserContactInvite[]      @relation("UserContactInviteSender")
  sentTripCollaboratorInvites   TripCollaboratorInvite[] @relation("TripCollaboratorInviteSender")
  feedbackEntries               Feedback[]
  plannerVersions               PlannerVersion[]         @relation("PlannerVersionAuthor")
  plannerTemplates              PlannerTemplate[]
  plannerExports                PlannerExport[]          @relation("PlannerExportOwner")
  tripPeople                     TripPerson[]             @relation("TripPersonMember")
  invitedTripPeople              TripPerson[]             @relation("TripPersonInviter")
  createdTripLogisticsTasks      TripLogisticsTask[]      @relation("TripLogisticsTaskCreator")
  liveSnapshotRevisions         TripLiveSnapshotRevision[] @relation("TripLiveSnapshotRevisionAuthor")
}

model MaraRequestLog {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
model UserPreference {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  preferredAdventureTypes  String[]
  typicalGroupSize         String?
  childrenAgeProfile       String?
  dietaryPreferences       String[]
  dietaryNotes             String?
  accessibilityNeeds       String[]
  accessibilityNotes       String?
  planningPriorities       String[]
  planningStyle            String?
  budgetPreference         String?
  travelDistancePreference String?
  planningHelpLevel        String?
  additionalNotes          String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String   @unique
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Park {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  resort      String
  description String?
  timezone    String              @default("America/New_York")
  opensAt     String
  closesAt    String
  attractions Attraction[]
  trips       Trip[]
  snapshots   ParkStateSnapshot[]
}

model Attraction {
  id                   String                      @id @default(cuid())
  parkId               String
  slug                 String
  name                 String
  category             AttractionCategory
  zone                 String
  description          String?
  thrillLevel          Int
  minHeight            Int?
  kidFriendly          Boolean                     @default(false)
  indoor               Boolean                     @default(false)
  familyFriendly       Boolean                     @default(false)
  durationMinutes      Int
  xCoord               Int
  yCoord               Int
  tags                 String[]
  typicalWaitProfile   Json
  status               AttractionOperationalStatus @default(OPEN)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  itineraryItems       ItineraryItem[]
  currentLocationTrips Trip[]                      @relation("TripCurrentLocation")
  park                 Park                        @relation(fields: [parkId], references: [id], onDelete: Cascade)

  @@unique([parkId, slug])
  @@index([parkId, category])
}

model Trip {
  id                          String                  @id @default(cuid())
  userId                      String
  parkId                      String
  name                        String
  startingLocation            String?
  visitDate                   DateTime
  status                      TripStatus              @default(DRAFT)
  plannerStatus               PlannerStatus           @default(ACTIVE)
  archivedAt                  DateTime?
  currentStep                 Int                     @default(0)
  simulatedTime               DateTime?
  currentLocationAttractionId String?
  latestPlanSummary           String?
  summary                     Json?
  liveSnapshot                Json?
  maraChatHistory             Json?
  liveSnapshotUpdatedAt       DateTime?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  currentLocation             Attraction?             @relation("TripCurrentLocation", fields: [currentLocationAttractionId], references: [id], onDelete: SetNull)
  park                        Park                    @relation(fields: [parkId], references: [id], onDelete: Cascade)
  partyProfile                PartyProfile?
  itineraryItems              ItineraryItem[]
  snapshots                   ParkStateSnapshot[]
  collaborators               TripCollaborator[]
  pendingInvites              TripCollaboratorInvite[]
  people                      TripPerson[]
  logisticsTasks              TripLogisticsTask[]
  notifications               Notification[]
  plannerVersions             PlannerVersion[]
  liveSnapshotRevisions       TripLiveSnapshotRevision[]
  plannerExports              PlannerExport[]
  user                        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, plannerStatus, visitDate])
  @@index([parkId, status])
  @@index([plannerStatus, updatedAt])
}

model PlannerVersion {
  id         String   @id @default(cuid())
  tripId      String
  userId      String?
  label       String
  snapshot    Json
  createdAt   DateTime @default(now())
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user        User?     @relation("PlannerVersionAuthor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tripId, createdAt])
  @@index([userId, createdAt])
}

model TripLiveSnapshotRevision {
  id              String   @id @default(cuid())
  tripId          String
  createdByUserId String?
  label           String
  snapshot        Json
  createdAt       DateTime @default(now())
  trip            Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdByUser   User?    @relation("TripLiveSnapshotRevisionAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tripId, createdAt])
  @@index([createdByUserId, createdAt])
}

model PlannerTemplate {
  id         String   @id @default(cuid())
  userId      String
  name        String
  snapshot    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PlannerExport {
  id           String   @id @default(cuid())
  tripId        String
  userId        String
  format        String
  brandingMode  String?
  metadata      Json?
  createdAt     DateTime @default(now())
  trip          Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user          User      @relation("PlannerExportOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
  @@index([userId, createdAt])
}

model PartyProfile {
  id                 String           @id @default(cuid())
  tripId             String           @unique
  partySize          Int
  kidsAges           Int[]
  thrillTolerance    ThrillTolerance
  walkingTolerance   WalkingTolerance
  preferredRideTypes String[]
  mustDoRideIds      String[]
  diningPreferences  String[]
  startTime          String
  breakStart         String?
  breakEnd           String?
  trip               Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TripCollaborator {
  id         String         @id @default(cuid())
  tripId     String
  userId     String
  accessRole TripAccessRole @default(EDIT)
  createdAt  DateTime       @default(now())
  trip       Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
}



model TripPerson {
  id                String               @id @default(cuid())
  tripId            String
  userId            String?
  invitedByUserId   String
  email             String
  displayName       String?
  attendanceStatus  TripAttendanceStatus @default(INVITED)
  plannerAccessRole TripAccessRole       @default(NONE)
  inviteAcceptedAt  DateTime?
  lastInvitedAt     DateTime?
  lastRemindedAt    DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  invitedByUser     User                 @relation("TripPersonInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  trip              Trip                 @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user              User?                @relation("TripPersonMember", fields: [userId], references: [id], onDelete: SetNull)
  tasks             TripLogisticsTask[]

  @@unique([tripId, email])
  @@index([userId])
  @@index([tripId, attendanceStatus])
}

model TripLogisticsTask {
  id             String                  @id @default(cuid())
  tripId         String
  assigneePersonId String
  createdByUserId String
  title          String
  category       TripLogisticsCategory
  status         TripLogisticsTaskStatus @default(TODO)
  source         TripLogisticsTaskSource @default(MANUAL)
  dueDate        DateTime?
  note           String?
  reminderNote   String?
  lastRemindedAt DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  assignee       TripPerson              @relation(fields: [assigneePersonId], references: [id], onDelete: Cascade)
  createdByUser  User                    @relation("TripLogisticsTaskCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  trip           Trip                    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, assigneePersonId])
  @@index([tripId, status])
  @@index([assigneePersonId, status])
}

model UserContact {
  id            String   @id @default(cuid())
  ownerUserId   String
  contactUserId String
  createdAt     DateTime @default(now())
  contactUser   User     @relation("UserContactMember", fields: [contactUserId], references: [id], onDelete: Cascade)
  ownerUser     User     @relation("UserContactOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, contactUserId])
  @@index([contactUserId])
}

model UserContactInvite {
  id          String   @id @default(cuid())
  ownerUserId String
  email       String
  createdAt   DateTime @default(now())
  ownerUser   User     @relation("UserContactInviteSender", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, email])
  @@index([email])
}

model TripCollaboratorInvite {
  id              String   @id @default(cuid())
  tripId           String
  invitedByUserId  String
  email            String
  createdAt        DateTime @default(now())
  invitedByUser    User     @relation("TripCollaboratorInviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  trip             Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, email])
  @@index([email])
}
model Notification {
  id         String               @id @default(cuid())
  userId     String
  tripId     String?
  actorUserId String?
  type       NotificationType
  severity   NotificationSeverity @default(INFO)
  title      String
  detail     String
  actionHref String?
  dedupeKey  String?
  metadata   Json?
  readAt     DateTime?
  createdAt  DateTime             @default(now())
  actorUser  User?                @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  trip       Trip?                @relation(fields: [tripId], references: [id], onDelete: SetNull)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([tripId, createdAt])
}
model Feedback {
  id          String         @id @default(cuid())
  userId      String
  message     String
  pagePath    String?
  screenshots Json?
  status      FeedbackStatus @default(NEW)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model ItineraryItem {
  id                   String              @id @default(cuid())
  tripId               String
  attractionId         String?
  title                String
  type                 ItineraryItemType
  order                Int
  startTime            DateTime
  endTime              DateTime
  arrivalWindowStart   DateTime
  arrivalWindowEnd     DateTime
  predictedWaitMinutes Int
  walkingMinutes       Int
  score                Float?
  reason               String
  explanation          String
  status               ItineraryItemStatus @default(PLANNED)
  completedAt          DateTime?
  metadata             Json?
  attraction           Attraction?         @relation(fields: [attractionId], references: [id], onDelete: SetNull)
  trip                 Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, order])
  @@index([tripId, status])
}

model ParkStateSnapshot {
  id            String   @id @default(cuid())
  tripId        String?
  parkId        String
  capturedAt    DateTime @default(now())
  effectiveTime DateTime
  weather       Json
  alerts        Json
  waitTimes     Json
  scenarioKey   String?
  park          Park     @relation(fields: [parkId], references: [id], onDelete: Cascade)
  trip          Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, effectiveTime])
  @@index([parkId, effectiveTime])
}






















