{
  "name": "parqara",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9 <23"
  },
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "build": "next build",
    "bundle:eb": "pwsh -NoProfile -File scripts/bundle-eb-web.ps1",
    "bundle:eb:web": "pwsh -NoProfile -File scripts/bundle-eb-web.ps1",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:homepage-ui": "node scripts/homepage-ui-check.mjs",
    "test:ui-regression": "node scripts/ui-regression-check.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:ui-assets": "node scripts/generate-ui-assets.mjs",
    "db:start": "docker compose up -d db",
    "db:stop": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset",
    "db:seed": "node prisma/seed.mjs",
    "db:bootstrap": "npm run db:migrate:deploy && npm run db:seed",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@openai/agents": "^0.7.1",
    "@prisma/client": "^6.16.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "next": "16.1.6",
    "openai": "^6.27.0",
    "prisma": "^6.16.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
